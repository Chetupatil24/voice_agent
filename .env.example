# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME="VaaniAI"
APP_VERSION="1.0.0"
DEBUG=false
SERVER_BASE_URL="https://yourdomain.com"

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://voice_agent:secret@localhost:5432/voice_agent_db"
POSTGRES_USER=voice_agent
POSTGRES_PASSWORD=secret
POSTGRES_DB=voice_agent_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/1"
CELERY_RESULT_BACKEND="redis://localhost:6379/2"

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="change-this-to-a-long-random-secret-key-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Owner / Super-Admin ──────────────────────────────────────────────────────
# Login at POST /api/v1/auth/owner/login
OWNER_EMAIL="owner@vaaniai.com"
# Generate hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
OWNER_PASSWORD_HASH="$2b$12$..."

# ─── Anthropic (Claude) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
CLAUDE_MODEL="claude-sonnet-4-5"

# ─── Deepgram (English STT) ───────────────────────────────────────────────────
DEEPGRAM_API_KEY="..."

# ─── Sarvam AI (Indian STT + TTS) ────────────────────────────────────────────
# Get your API key from: https://dashboard.sarvam.ai
SARVAM_API_KEY="..."

# ─── Exotel (India telephony — primary) ──────────────────────────────────────
EXOTEL_API_KEY="..."
EXOTEL_API_TOKEN="..."
EXOTEL_ACCOUNT_SID="..."
EXOTEL_SUBDOMAIN="api.exotel.com"

# ─── Twilio (secondary / fallback) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."

# ─── Razorpay (Billing) ───────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_live_..."
RAZORPAY_KEY_SECRET="..."

# ─── Meta WABA (WhatsApp Business API) ───────────────────────────────────────
# Get from Meta for Developers → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxx"           # System user token (never expires)
WHATSAPP_PHONE_NUMBER_ID="1234567890"        # Phone Number ID (not the actual number)
WHATSAPP_BUSINESS_ACCOUNT_ID="9876543210"   # WABA ID

# ─── Resend (transactional email) ────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="VaaniAI <noreply@vaaniai.com>"

# ─── File Upload / Cloudflare R2 ─────────────────────────────────────────────
UPLOAD_DIR="./uploads"
MAX_UPLOAD_SIZE_MB=50
CLOUDFLARE_R2_ACCESS_KEY="..."
CLOUDFLARE_R2_SECRET_KEY="..."
CLOUDFLARE_R2_BUCKET="vaaniai-uploads"
CLOUDFLARE_R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL=""     # optional: your custom domain e.g. https://assets.vaaniai.com

# ─── RAG Settings ─────────────────────────────────────────────────────────────
EMBEDDING_MODEL="all-MiniLM-L6-v2"
EMBEDDING_DIMENSION=384
MAX_RAG_RESULTS=5
RAG_SIMILARITY_THRESHOLD=0.7

# ─── Google Calendar ──────────────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
GOOGLE_CALENDAR_ID="primary"

# ─── Sentry (error tracking) ──────────────────────────────────────────────────
# https://sentry.io/settings/<org>/projects/<project>/keys/
SENTRY_DSN="https://xxxx@o0.ingest.sentry.io/0"
SENTRY_ENVIRONMENT="production"
